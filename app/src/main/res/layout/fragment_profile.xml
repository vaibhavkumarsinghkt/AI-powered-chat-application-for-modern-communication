<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="10dp"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/white"
    tools:context=".ProfileFragment">


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welocome !!"
        android:layout_marginTop="30dp"
        android:textSize="40sp"
        android:textColor="@color/primary"

        android:textStyle="bold"
/>



   <ImageView

       android:layout_marginTop="50dp"
       android:layout_marginBottom="5dp"
       android:layout_width="200dp"
       android:layout_height="200dp"
       android:src="@drawable/ic_person"/>


    <TextView

        android:id="@+id/user_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Utkarsh Yadav"
        android:textSize="28sp"
        android:textColor="@color/primary"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/ph_number"
        android:layout_marginTop="5dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Phone: + 91 9999999999"
        android:textSize="18sp"
        android:textColor="@color/black"
        />

    <TextView
        android:id="@+id/btn_change_name"

        android:layout_marginTop="15dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Change user name?"
        android:textSize="18sp"
        android:textColor="@color/black"
        />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/et_holder"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginHorizontal="17dp"
        android:layout_marginVertical="17dp"
        app:boxCornerRadiusBottomEnd="17dp"
        app:boxCornerRadiusTopStart="17dp"
        app:boxCornerRadiusTopEnd="17dp"
        app:boxCornerRadiusBottomStart="17dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_username"
            android:layout_width="match_parent"
            android:layout_height="match_parent"

            android:inputType="text"


            android:hint="Enter your new user name "
            android:textSize="20sp"/>



    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:visibility="gone"
        android:id="@+id/btn_continue"
        android:layout_width="match_parent"
        android:layout_height="50.5dp"
        android:text="Change"
        android:textSize="23sp"
        android:backgroundTint="@color/primary"
        android:layout_marginHorizontal="20dp"
        app:cornerRadius="15dp"/>


    <TextView

        android:id="@+id/logout"

        android:layout_marginTop="15dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LogOut ?"
        android:textSize="18sp"
        android:textColor="@color/black"
        />





</LinearLayout>